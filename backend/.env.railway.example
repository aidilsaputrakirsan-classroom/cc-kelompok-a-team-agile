# Copy to .env.railway and fill in your Railway credentials.
# Used by scripts/seed-db-to-railway.ps1 and scripts/seed-db-to-railway.sh

# Public URL — use this when seeding from your local machine
DATABASE_PUBLIC_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST.railway.app:PORT/sihp

# Internal URL — only reachable inside Railway network (not for local seeding)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres.railway.internal:5432/sihp

# Local database (Docker: port 5435, native Postgres: port 5432)
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5435/sihp

# Optional: use docker exec on this container instead of local pg_dump
LOCAL_DB_CONTAINER=sihp-db
