# =============================================
# Environment Variables — Cloud App Backend
# =============================================
# Salin file ini menjadi .env dan isi nilainya:
#   cp backend/.env.example backend/.env

# ---------------------------
# DATABASE
# ---------------------------
# Format PostgreSQL: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:postgre@localhost:5432/cloudapp

# ---------------------------
# APP / SERVER
# ---------------------------
APP_HOST=127.0.0.1
APP_PORT=8000

# ---------------------------
# ENVIRONMENT
# ---------------------------
# Nilai yang valid: development | production | testing
APP_ENV=development

# ---------------------------
# CORS (opsional)
# ---------------------------
# Pisahkan beberapa origin dengan koma, atau gunakan * untuk semua
ALLOWED_ORIGINS=*
